<script>
const toggleBtn = document.getElementById('toggleCampaignForm');
const formPanel = document.getElementById('campaignFormPanel');
const positionTabs = document.getElementById('positionTabs');
const candidateTiles = Array.from(document.querySelectorAll('.candidate-tile'));
const emptyElectionState = document.getElementById('emptyElectionState');

toggleBtn.addEventListener('click', () => {
formPanel.classList.toggle('open');

if (formPanel.classList.contains('open')) {
toggleBtn.textContent = 'Hide Submission Form';
formPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
} else {
toggleBtn.textContent = 'Submit Campaign Material';
}
});

function filterCandidates(position) {
let visibleCount = 0;

candidateTiles.forEach((tile) => {
const tilePosition = tile.dataset.position || '';

if (position === 'all' || tilePosition === position) {
tile.classList.remove('hidden');
visibleCount++;
} else {
tile.classList.add('hidden');
}
});

emptyElectionState.style.display = visibleCount === 0 ? 'block' : 'none';
}

positionTabs.querySelectorAll('[data-position]').forEach((btn) => {
btn.addEventListener('click', () => {
const position = btn.dataset.position || 'all';

positionTabs.querySelectorAll('[data-position]').forEach((tab) => {
tab.classList.remove('active');
});

btn.classList.add('active');
filterCandidates(position);
});
});

filterCandidates('all');
</script>
